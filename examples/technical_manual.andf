}
.andf-callout-icon { float: left; margin-right: 6px; }
.andf-callout p { margin: 0; }

.andf-hr { border: none; border-top: 1px solid #e5e7eb; margin: 1.2em 0; }

code { font-family: JetBrains Mono, monospace; background: #f8f8f8; padding: 1px 4px; border-radius: 3px; font-size: .9em; }
sup.ref { font-size: .75em; color: #1a73e8; }

/* ─── Cover page ─── */
.andf-cover { padding-top: 30mm; text-align: center; }
.andf-cover .andf-h1 { font-size: 2.4em; border: none; margin-bottom: .2em; }
.andf-cover-subtitle { font-size: 1.2em; color: #6b7280; margin-bottom: 2em; }
