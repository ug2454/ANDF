}
figcaption { font-size: .85em; color: #757575; margin-top: .4em; text-align: center; }

.andf-table-wrap { margin: 1em 0; overflow-x: auto; }
.andf-table-caption { font-size: .9em; color: #757575; margin-bottom: .4em; font-style: italic; }
.andf-table { width: 100%; border-collapse: collapse; font-size: .9em; }
.andf-table th {
  background: #f5f5f5;
