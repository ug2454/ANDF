}
.andf-callout-info    { background: #e3f2fd; border-color: #3b82f6; }
.andf-callout-warning { background: #fff8e1; border-color: #f59e0b; }
.andf-callout-error   { background: #ffebee; border-color: #ef4444; }
.andf-callout-success { background: #e8f5e9; border-color: #22c55e; }
.andf-callout-tip     { background: #f3e5f5; border-color: #8b5cf6; }
.andf-callout-title {
  font-weight: 700;
  margin-bottom: .4em;
  font-size: 1em;
  display: flex;
  align-items: center;
  gap: 6px;
}
.andf-callout-icon { float: left; margin-right: 6px; }
.andf-callout p { margin: 0; }

.andf-hr { border: none; border-top: 1px solid #e0e0e0; margin: 1.2em 0; }

code { font-family: Consolas, monospace; background: #f5f5f5; padding: 1px 4px; border-radius: 3px; font-size: .9em; }
sup.ref { font-size: .75em; color: #1565c0; }

/* ─── Cover page ─── */
.andf-cover { padding-top: 30mm; text-align: center; }
.andf-cover .andf-h1 { font-size: 2.4em; border: none; margin-bottom: .2em; }
.andf-cover-subtitle { font-size: 1.2em; color: #757575; margin-bottom: 2em; }
.andf-cover-authors { font-size: 1em; color: #212121; margin-bottom: .5em; }
.andf-cover-date { font-size: .9em; color: #757575; }
.andf-cover-divider { margin: 2em auto; width: 80px; height: 3px; background: #1565c0; border: none; }

/* ─── Print ─── */
@media print {
  #andf-toolbar, #andf-toc { display: none !important; }
  #andf-viewer { padding-top: 0; background: white; }
